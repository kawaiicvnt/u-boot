&pinctrl_far_alive {
	gpa5: gpa5-gpio-bank {
		gpio-controller;
		#gpio-cells = <2>;
		interrupt-controller;
		#interrupt-cells = <2>;
		interrupts = <GIC_SPI 60 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 61 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 62 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 63 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 64 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 65 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 66 IRQ_TYPE_LEVEL_HIGH 0>,
			     <GIC_SPI 67 IRQ_TYPE_LEVEL_HIGH 0>;
	};

	pcie1_wlan_host_wake: pcie1-wlan-host-wake-pins {
		samsung,pins = "gpa5-3";
		samsung,pin-function = <GS101_PIN_FUNC_EINT>;
		samsung,pin-pud = <GS101_PIN_PULL_NONE>;
		samsung,pin-con-pdn = <GS101_PIN_PDN_PREV>;
	};
};

