		cmu_hsi0: clock-controller@11000000 {
			compatible = "google,zuma-cmu-hsi0";
			reg = <0x11000000 0x10000>;
			#clock-cells = <1>;

			clocks = <&ext_24_5m>,
				 <&cmu_top CLK_DOUT_CMU_HSI0_BUS>,
				 <&cmu_top CLK_DOUT_CMU_HSI0_DPGTC>,
				 <&cmu_top CLK_DOUT_CMU_HSI0_USB31DRD>,
				 <&cmu_top CLK_DOUT_CMU_HSI0_USBDPDBG>;
			clock-names = "oscclk", "bus", "dpgtc", "usb31drd",
				      "usbdpdbg";
			samsung,sysreg = <&sysreg_hsi0>;
		};

		sysreg_hsi0: syscon@11020000 {
			compatible = "google,gs101-hsi0-sysreg", "syscon";
			reg = <0x11020000 0x10000>;
			clocks = <&cmu_hsi0 CLK_GOUT_HSI0_SYSREG_HSI0_PCLK>;
		};

		sysreg_hsi1: syscon@12020000 {
			compatible = "google,gs101-hsi0-sysreg", "syscon";
			reg = <0x12020000 0x10000>;
			clocks = <&cmu_hsi0 CLK_GOUT_HSI0_SYSREG_HSI0_PCLK>;
		};

		usbdrd32_phy: phy@11100000 {
			compatible = "google,zuma-usb32drd-phy";
			reg = <0x11100000 0x10000>;

			clocks = <&cmu_hsi0 CLK_MOUT_HSI0_BUS>;
			clock-names = "phy";

			#phy-cells = <1>;
			phys = <&usb_hsphy>;
			phy-names = "hs";

			samsung,pmu-syscon = <&pmu_system_controller>;

			// power-domains = <&pd_hsi0>;
			status = "disabled";
		};

		usb_hsphy: phy@11110000 {
			compatible = "samsung,exynos2200-eusb2-phy";
			reg = <0x11110000 0x10000>;

			assigned-clocks = <&cmu_hsi0 CLK_MOUT_HSI0_USB20_REF>;
			assigned-clock-parents = <&cmu_hsi0 CLK_MOUT_HSI0_TCXO_USER>;

			clocks = <&cmu_hsi0 CLK_MOUT_HSI0_USB20_REF>,
				 <&cmu_hsi0 CLK_MOUT_HSI0_BUS>,
				 <&cmu_hsi0 CLK_DOUT_DIV_CLK_HSI0_EUSB>;
			clock-names = "ref", "bus", "ctrl";

			#phy-cells = <0>;
			hs_tune_param = <&usb_hs_tune>;

			power-domains = <&pd_hsi0>;

			status = "okay";
		};

		usbdrd32: usb@11210000 {
			compatible = "samsung,exynos2200-dwusb3";
			ranges = <0x0 0x11210000 0x10000>;
			clocks = <&cmu_hsi0 CLK_MOUT_HSI0_BUS>;
			clock-names = "link_aclk";
			#address-cells = <1>;
			#size-cells = <1>;
			// power-domains = <&pd_hsi0>;
			// samsung,sysreg-hsi0 = <&sysreg_hsi0>;

			status = "disabled";

			usbdrd32_dwc3: usb@0 {
				compatible = "snps,dwc3";
				reg = <0x0 0x10000>;
				clocks = <&cmu_hsi0 CLK_MOUT_HSI0_USB31DRD>;
				clock-names = "ref";
				interrupts = <GIC_SPI 402 IRQ_TYPE_LEVEL_HIGH 0>;
				phys = <&usbdrd32_phy 0>;
				phy-names = "usb2-phy";
				snps,dis-u2-freeclk-exists-quirk;
				snps,gfladj-refclk-lpm-sel-quirk;
				snps,quirk-frame-length-adjustment = <0x20>;
				snps,has-lpm-erratum;
				snps,lpm-nyet-threshold = <0>;
				snps,usb2-gadget-lpm-disable;
				snps,dis-u1-entry-quirk;
				snps,dis-u2-entry-quirk;
				snps,dis_u3_susphy_quirk;
				status = "disabled";
			};
		};

		pinctrl_hsi1: pinctrl@12040000 {
			compatible = "google,zuma-pinctrl";
			reg = <0x12040000 0x00001000>;
			/* TODO: update once support for this CMU exists */
			clocks = <0>;
			clock-names = "pclk";
			interrupts = <GIC_SPI 413 IRQ_TYPE_LEVEL_HIGH 0>;
		};

		cmu_hsi2: clock-controller@13000000 {
			compatible = "google,zuma-cmu-hsi2";
			reg = <0x13000000 0x10000>;
			#clock-cells = <1>;
			clocks = <&ext_24_5m>,
				 <&cmu_top CLK_DOUT_CMU_HSI2_BUS>,
				 <&cmu_top CLK_DOUT_CMU_HSI2_PCIE>,
				 <&cmu_top CLK_DOUT_CMU_HSI2_UFS_EMBD>,
				 <&cmu_top CLK_DOUT_CMU_HSI2_MMC_CARD>;
			clock-names = "oscclk", "bus", "pcie", "ufs", "mmc";
			samsung,sysreg = <&sysreg_hsi2>;
		};

		sysreg_hsi2: syscon@13020000 {
			compatible = "google,gs101-hsi2-sysreg", "syscon";
			reg = <0x13020000 0x10000>;
			clocks = <&cmu_hsi2 CLK_GOUT_HSI2_SYSREG_HSI2_PCLK>;
		};

		pinctrl_hsi2: pinctrl@13040000 {
			compatible = "google,zuma-pinctrl";
