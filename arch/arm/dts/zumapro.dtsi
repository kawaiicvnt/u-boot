			<2 STR_CFG(STR_SPTLB(0x02, 0x02), S2_EN, BL2, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x60) STR_MASK(0x70)>,
			<3 STR_CFG(STR_SPTLB(0x03, 0x03), S2_EN, BL1, PREF_PRED, STLB_NONE, PTLB_NONE) DIR_RW STR_ID(0x00) STR_MASK(0x78)>,
