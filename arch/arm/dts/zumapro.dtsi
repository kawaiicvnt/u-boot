			<7 STR_CFG(STR_SPTLB(0x07, 0x07), S2_EN, BL1, PREF_PRED, STLB_NONE, PTLB_NONE) DIR_RW STR_ID(0x18) STR_MASK(0x78)>,
			<8 STR_CFG(STR_SPTLB(0x08, 0x08), S2_EN, BL1, PREF_PRED, STLB_NONE, PTLB_NONE) DIR_RW STR_ID(0x28) STR_MASK(0x78)>,
			<9 STR_CFG(STR_SPTLB(0x09, 0x09), S2_EN, BL1, PREF_PRED, STLB_NONE, PTLB_NONE) DIR_RW STR_ID(0x30) STR_MASK(0x70)>;
			pmmu1,default_stream = <STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF)>;
			pmmu1,stream_property =
