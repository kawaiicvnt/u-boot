			reg = <0x16C40000 0x10000>;
			clocks = <&ext_24_5m>;
			clock-names = "sysmmu";

			interrupts = <0 331 IRQ_TYPE_LEVEL_HIGH 0>,
			<0 332 IRQ_TYPE_LEVEL_HIGH 0>;

			qos = <15>;

			sysmmu,secure-irq;
			sysmmu,secure_base = <0x16C50000>;
			power-domains = <&pd_eh>;

			port-name = "EH";
			#iommu-cells = <0>;
			pmmu0,default_stream = <STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF)>;
			pmmu0,stream_property =
			<1 STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x10) STR_MASK(0x3E)>,
			<2 STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_WRITE STR_ID(0x14) STR_MASK(0x3E)>,
			<3 STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_WRITE STR_ID(0x40) STR_MASK(0x60)>,
			<4 STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x20) STR_MASK(0x60)>;
		};

		sysmmu_aur: iommu@20A50000 {
