		pmu_system_controller: system-controller@15460000 {
			compatible = "google,gs101-pmu";
			reg = <0x15460000 0x10000>;
			google,pmu-intr-gen-syscon = <&pmu_intr_gen>;
			clocks = <&ext_26m>;
			clock-names = "clkout0";

			mipi_phy: mipi-phy {
				compatible = "samsung,exynos7870-mipi-video-phy";
				#phy-cells = <1>;
				samsung,disp-sysreg = <&sysreg_dpu>;
				samsung,cam0-sysreg = <&sysreg_cam0>;
			};

			mipi_phy_dsim0_m4m4: mipi-phy-dsim {
				compatible = "samsung,mipi-phy-m4m4";
				isolation = <0x3eb8>;
				owner = <0>;
				#phy-cells = <1>;
			};

			poweroff: syscon-poweroff {
				compatible = "syscon-poweroff";
				offset = <0x3e9c>; /* PAD_CTRL_PWR_HOLD */
				mask = <0x00000100>;
				value = <0x0>;
			};

			reboot: syscon-reboot {
				compatible = "google,gs101-reboot";
			};

			reboot-mode {
				compatible = "syscon-reboot-mode";
				offset = <0x0810>; /* EXYNOS_PMU_SYSIP_DAT0 */
				mode-bootloader = <0xfc>;
				mode-charge = <0x0a>;
				mode-dm-verity-device-corrupted = <0x50>;
				mode-fastboot = <0xfa>;
				mode-reboot-ab-update = <0x52>;
				mode-recovery = <0xff>;
				mode-rescue = <0xf9>;
				mode-shutdown-thermal = <0x51>;
				mode-shutdown-thermal-battery = <0x51>;
			};
		};

		pmu_intr_gen: syscon@15470000 {
			compatible = "google,zuma-pmu-intr-gen", "syscon";
			reg = <0x15470000 0x10000>;
		};

