			<7 STR_CFG(STR_SPTLB(0x07, 0x07), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_NONE) DIR_RW STR_ID(0x18) STR_MASK(0x78)>,
			<8 STR_CFG(STR_SPTLB(0x08, 0x08), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_NONE) DIR_RW STR_ID(0x28) STR_MASK(0x78)>,
			<9 STR_CFG(STR_SPTLB(0x09, 0x09), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x30) STR_MASK(0x70)>;
			sysmmu,async-fault;
		};

		sysmmu_aoc: iommu@19090000 {
			compatible = "samsung,exynos-sysmmu";
			reg = <0x19090000 0x10000>;
			clocks = <&ext_24_5m>;
			clock-names = "sysmmu";

			interrupts = <0 132 IRQ_TYPE_LEVEL_HIGH 0>,
			<0 133 IRQ_TYPE_LEVEL_HIGH 0>;

			qos = <15>;

			sysmmu,secure-irq;
			sysmmu,secure_base = <0x190A0000>;

			port-name = "AOC";
			sysmmu,leave-enabled-on-suspend;
			#iommu-cells = <0>;
			pmmu0,default_stream = <STR_CFG(STR_SPTLB(0x00, 0x00), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF)>;
			pmmu0,stream_property =
