			<2 STR_CFG(STR_SPTLB(0x02, 0x02), S2_EN, BL1, PREF_PRED, STLB_NONE, PTLB_NONE) DIR_RW STR_ID(0x60) STR_MASK(0x70)>,
			<3 STR_CFG(STR_SPTLB(0x03, 0x03), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x00) STR_MASK(0x78)>,
			<4 STR_CFG(STR_SPTLB(0x04, 0x04), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x10) STR_MASK(0x78)>,
			<5 STR_CFG(STR_SPTLB(0x05, 0x05), S2_EN, BL1, PREF_PRED, STLB_PREF, PTLB_PREF) DIR_RW STR_ID(0x20) STR_MASK(0x78)>,
