#include <dt-bindings/clock/google,zuma.h>
#include <dt-bindings/clock/google,zuma-acpm.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/arm-gic.h>
#include <dt-bindings/soc/samsung,exynos-usi.h>
#include <dt-bindings/soc/samsung_sysmmu_v9.h>


/ {
	compatible = "google,zumapro", "google,gs101";
	#address-cells = <2>;
	#size-cells = <1>;

	interrupt-parent = <&gic>;

	aliases {
		pinctrl0 = &pinctrl_gpio_alive;
		pinctrl1 = &pinctrl_gpio_custom_alive;
		pinctrl2 = &pinctrl_far_alive;
		pinctrl3 = &pinctrl_gsacore0;
		pinctrl4 = &pinctrl_gsacore1;
		pinctrl5 = &pinctrl_gsacore2;
		pinctrl6 = &pinctrl_gsacore3;
		pinctrl7 = &pinctrl_gsactrl;
		pinctrl8 = &pinctrl_hsi1;
		pinctrl9 = &pinctrl_hsi2;
		pinctrl10 = &pinctrl_hsi2ufs;
		pinctrl11 = &pinctrl_peric0;
		pinctrl12 = &pinctrl_peric1;
	};

	cpus {
		#address-cells = <1>;
		#size-cells = <0>;

		cpu-map {
			cluster0 {
				core0 {
					cpu = <&cpu0>;
				};
				core1 {
					cpu = <&cpu1>;
				};
				core2 {
					cpu = <&cpu2>;
				};
				core3 {
					cpu = <&cpu3>;
				};
			};

			cluster1 {
				core0 {
					cpu = <&cpu4>;
				};
				core1 {
					cpu = <&cpu5>;
				};
				core2 {
					cpu = <&cpu6>;
				};
			};

			cluster2 {
				core0 {
					cpu = <&cpu7>;
				};
			};
		};

		cpu0: cpu@0 {
			device_type = "cpu";
			compatible = "arm,cortex-a520";
			reg = <0x0000>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL0>;
			enable-method = "psci";
			// cpu-idle-states = <&hayes_cpu_sleep>;
			capacity-dmips-mhz = <449>;
			dynamic-power-coefficient = <176>;
			operating-points-v2 = <&cpucl0_opp_table>;
			// clock-frequency = <2000000000>;
		};

		cpu1: cpu@100 {
			device_type = "cpu";
			compatible = "arm,cortex-a520";
			reg = <0x0100>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL0>;
			enable-method = "psci";
			// cpu-idle-states = <&hayes_cpu_sleep>;
			capacity-dmips-mhz = <449>;
			dynamic-power-coefficient = <176>;
			operating-points-v2 = <&cpucl0_opp_table>;
			// clock-frequency = <2000000000>;
		};

		cpu2: cpu@200 {
			device_type = "cpu";
			compatible = "arm,cortex-a520";
			reg = <0x0200>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL0>;
			enable-method = "psci";
			// cpu-idle-states = <&hayes_cpu_sleep>;
			capacity-dmips-mhz = <449>;
			dynamic-power-coefficient = <176>;
			operating-points-v2 = <&cpucl0_opp_table>;
			// clock-frequency = <2000000000>;
		};

		cpu3: cpu@300 {
			device_type = "cpu";
			compatible = "arm,cortex-a520";
			reg = <0x0300>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL0>;
			enable-method = "psci";
			// cpu-idle-states = <&hayes_cpu_sleep>;
			capacity-dmips-mhz = <449>;
			dynamic-power-coefficient = <176>;
			operating-points-v2 = <&cpucl0_opp_table>;
			// clock-frequency = <2000000000>;
		};

		cpu4: cpu@400 {
			device_type = "cpu";
			compatible = "arm,cortex-a720";
			reg = <0x0400>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL1>;
			enable-method = "psci";
			// cpu-idle-states = <&hunter_cpu_sleep>;
			capacity-dmips-mhz = <850>;
			dynamic-power-coefficient = <325>;
			operating-points-v2 = <&cpucl1_opp_table>;
			// clock-frequency = <3000000000>;
		};

		cpu5: cpu@500 {
			device_type = "cpu";
			compatible = "arm,cortex-a720";
			reg = <0x0500>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL1>;
			enable-method = "psci";
			// cpu-idle-states = <&hunter_cpu_sleep>;
			capacity-dmips-mhz = <850>;
			dynamic-power-coefficient = <325>;
			operating-points-v2 = <&cpucl1_opp_table>;
			// clock-frequency = <3000000000>;
		};

		cpu6: cpu@600 {
			device_type = "cpu";
			compatible = "arm,cortex-a720";
			reg = <0x0600>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL2>;
			enable-method = "psci";
			// cpu-idle-states = <&hunter_cpu_sleep>;
			capacity-dmips-mhz = <850>;
			dynamic-power-coefficient = <325>;
			operating-points-v2 = <&cpucl1_opp_table>;
			// clock-frequency = <3000000000>;
		};

		cpu7: cpu@700 {
			device_type = "cpu";
			compatible = "arm,cortex-x4";
			reg = <0x0700>;
			clocks = <&acpm_ipc GS101_CLK_ACPM_DVFS_CPUCL2>;
			enable-method = "psci";
			// cpu-idle-states = <&hunterelp_cpu_sleep>;
			capacity-dmips-mhz = <1024>;
			dynamic-power-coefficient = <748>;
			operating-points-v2 = <&cpucl2_opp_table>;
			// clock-frequency = <3400000000>;
		};

		idle-states {
			entry-method = "psci";

			hayes_cpu_sleep: cpu-hayes-sleep {
				idle-state-name = "c2";
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x0010000>;
				local-timer-stop;
				entry-latency-us = <70>;
				exit-latency-us = <160>;
				min-residency-us = <2000>;
			};

			hunter_cpu_sleep: cpu-hunter-sleep {
				idle-state-name = "c2";
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x0010000>;
				local-timer-stop;
				entry-latency-us = <150>;
				exit-latency-us = <190>;
				min-residency-us = <2500>;
			};

			hunterelp_cpu_sleep: cpu-hunterelp-sleep {
				idle-state-name = "c2";
				compatible = "arm,idle-state";
				arm,psci-suspend-param = <0x0010000>;
				local-timer-stop;
				entry-latency-us = <235>;
				exit-latency-us = <220>;
				min-residency-us = <3500>;
			};
		};
	};

	cpucl0_opp_table: opp-table-0 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-300000000 {
			opp-hz = /bits/ 64 <300000000>;
			opp-microvolt = <537500>;
			clock-latency-ns = <500000>;
		};

		opp-574000000 {
			opp-hz = /bits/ 64 <574000000>;
			opp-microvolt = <600000>;
			clock-latency-ns = <500000>;
		};

		opp-738000000 {
			opp-hz = /bits/ 64 <738000000>;
			opp-microvolt = <618750>;
			clock-latency-ns = <500000>;
		};

		opp-930000000 {
			opp-hz = /bits/ 64 <930000000>;
			opp-microvolt = <668750>;
			clock-latency-ns = <500000>;
		};

		opp-1098000000 {
			opp-hz = /bits/ 64 <1098000000>;
			opp-microvolt = <712500>;
			clock-latency-ns = <500000>;
		};

		opp-1197000000 {
			opp-hz = /bits/ 64 <1197000000>;
			opp-microvolt = <731250>;
			clock-latency-ns = <500000>;
		};

		opp-1328000000 {
			opp-hz = /bits/ 64 <1328000000>;
			opp-microvolt = <762500>;
			clock-latency-ns = <500000>;
		};

		opp-1401000000 {
			opp-hz = /bits/ 64 <1401000000>;
			opp-microvolt = <781250>;
			clock-latency-ns = <500000>;
		};

		opp-1598000000 {
			opp-hz = /bits/ 64 <1598000000>;
			opp-microvolt = <831250>;
			clock-latency-ns = <500000>;
		};

		opp-1704000000 {
			opp-hz = /bits/ 64 <1704000000>;
			opp-microvolt = <862500>;
			clock-latency-ns = <500000>;
		};

		opp-1803000000 {
			opp-hz = /bits/ 64 <1803000000>;
			opp-microvolt = <906250>;
			clock-latency-ns = <500000>;
		};
	};

	cpucl1_opp_table: opp-table-1 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-400000000 {
			opp-hz = /bits/ 64 <400000000>;
			opp-microvolt = <506250>;
			clock-latency-ns = <500000>;
		};

		opp-553000000 {
			opp-hz = /bits/ 64 <553000000>;
			opp-microvolt = <537500>;
			clock-latency-ns = <500000>;
		};

		opp-696000000 {
			opp-hz = /bits/ 64 <696000000>;
			opp-microvolt = <562500>;
			clock-latency-ns = <500000>;
		};

		opp-799000000 {
			opp-hz = /bits/ 64 <799000000>;
			opp-microvolt = <581250>;
			clock-latency-ns = <500000>;
		};

		opp-910000000 {
			opp-hz = /bits/ 64 <910000000>;
			opp-microvolt = <606250>;
			clock-latency-ns = <500000>;
		};

		opp-1024000000 {
			opp-hz = /bits/ 64 <1024000000>;
			opp-microvolt = <625000>;
			clock-latency-ns = <500000>;
		};

		opp-1197000000 {
			opp-hz = /bits/ 64 <1197000000>;
			opp-microvolt = <662500>;
			clock-latency-ns = <500000>;
		};

		opp-1328000000 {
			opp-hz = /bits/ 64 <1328000000>;
			opp-microvolt = <687500>;
			clock-latency-ns = <500000>;
		};

		opp-1491000000 {
			opp-hz = /bits/ 64 <1491000000>;
			opp-microvolt = <731250>;
			clock-latency-ns = <500000>;
		};

		opp-1663000000 {
			opp-hz = /bits/ 64 <1663000000>;
			opp-microvolt = <775000>;
			clock-latency-ns = <500000>;
		};

		opp-1836000000 {
			opp-hz = /bits/ 64 <1836000000>;
			opp-microvolt = <818750>;
			clock-latency-ns = <500000>;
		};

		opp-1999000000 {
			opp-hz = /bits/ 64 <1999000000>;
			opp-microvolt = <868750>;
			clock-latency-ns = <500000>;
		};

		opp-2130000000 {
			opp-hz = /bits/ 64 <2130000000>;
			opp-microvolt = <918750>;
			clock-latency-ns = <500000>;
		};

		opp-2253000000 {
			opp-hz = /bits/ 64 <2253000000>;
			opp-microvolt = <968750>;
			clock-latency-ns = <500000>;
		};
	};

	cpucl2_opp_table: opp-table-2 {
		compatible = "operating-points-v2";
		opp-shared;

		opp-500000000 {
			opp-hz = /bits/ 64 <500000000>;
			opp-microvolt = <500000>;
			clock-latency-ns = <500000>;
		};

		opp-851000000 {
			opp-hz = /bits/ 64 <851000000>;
			opp-microvolt = <556250>;
			clock-latency-ns = <500000>;
		};

		opp-984000000 {
			opp-hz = /bits/ 64 <984000000>;
			opp-microvolt = <575000>;
			clock-latency-ns = <500000>;
		};

		opp-1106000000 {
			opp-hz = /bits/ 64 <1106000000>;
			opp-microvolt = <606250>;
			clock-latency-ns = <500000>;
		};

		opp-1277000000 {
			opp-hz = /bits/ 64 <1277000000>;
			opp-microvolt = <631250>;
			clock-latency-ns = <500000>;
		};

		opp-1426000000 {
			opp-hz = /bits/ 64 <1426000000>;
			opp-microvolt = <662500>;
			clock-latency-ns = <500000>;
		};

		opp-1582000000 {
			opp-hz = /bits/ 64 <1582000000>;
			opp-microvolt = <693750>;
			clock-latency-ns = <500000>;
		};

		opp-1745000000 {
			opp-hz = /bits/ 64 <1745000000>;
			opp-microvolt = <731250>;
			clock-latency-ns = <500000>;
		};

		opp-1826000000 {
			opp-hz = /bits/ 64 <1826000000>;
			opp-microvolt = <750000>;
			clock-latency-ns = <500000>;
		};

		opp-2048000000 {
			opp-hz = /bits/ 64 <2048000000>;
			opp-microvolt = <793750>;
			clock-latency-ns = <500000>;
		};

		opp-2188000000 {
			opp-hz = /bits/ 64 <2188000000>;
			opp-microvolt = <831250>;
			clock-latency-ns = <500000>;
		};

		opp-2252000000 {
			opp-hz = /bits/ 64 <2252000000>;
			opp-microvolt = <850000>;
			clock-latency-ns = <500000>;
		};

		opp-2401000000 {
			opp-hz = /bits/ 64 <2401000000>;
			opp-microvolt = <887500>;
			clock-latency-ns = <500000>;
		};

		opp-2507000000 {
			opp-hz = /bits/ 64 <2507000000>;
			opp-microvolt = <925000>;
			clock-latency-ns = <500000>;
		};

		opp-2630000000 {
			opp-hz = /bits/ 64 <2630000000>;
			opp-microvolt = <968750>;
			clock-latency-ns = <500000>;
		};

		opp-2704000000 {
			opp-hz = /bits/ 64 <2704000000>;
			opp-microvolt = <1000000>;
			clock-latency-ns = <500000>;
		};

		opp-2802000000 {
			opp-hz = /bits/ 64 <2802000000>;
			opp-microvolt = <1056250>;
			clock-latency-ns = <500000>;
		};
	};

	memory@b80000000 {
		device_type = "memory";
		reg = <0x0b 0x80000000 0x60f83000>;
	};

	memory@b00000000 {
		device_type = "memory";
		reg = <0x0b 0x00 0x80000000>;
	};

	memory@a80000000 {
		device_type = "memory";
		reg = <0x0a 0x80000000 0x80000000>;
	};

	memory@a00000000 {
		device_type = "memory";
		reg = <0x0a 0x00 0x80000000>;
	};

	memory@980000000 {
		device_type = "memory";
		reg = <0x09 0x80000000 0x80000000>;
	};

	memory@900000000 {
		device_type = "memory";
		reg = <0x09 0x00 0x80000000>;
	};

	memory@880000000 {
		device_type = "memory";
		reg = <0x08 0x80000000 0x80000000>;
	};

	/* ect node is required to be present by bootloader */
	ect {
	};

	usb_hs_tune: hs-tune-phy {
		hs_tune_cnt = <12>;

		hs_tune1 {
			tune_name = "tx_fsls_slew_rate";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune2 {
			tune_name = "tx_fsls_vref_tune";
			tune_value = <0x0 0x0>;
		};

		hs_tune3 {
			tune_name = "tx_fsls_vreg_bypass";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune4 {
			tune_name = "tx_hs_vref_tune";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune5 {
			tune_name = "tx_hs_xv";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune6 {
			tune_name = "tx_preemp";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune7 {
			tune_name = "tx_res";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune8 {
			tune_name = "tx_rise";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune9 {
			tune_name = "rx_eq_ctle";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune10 {
			tune_name = "rx_hs_term_en";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune11 {
			tune_name = "rx_hs_tune";
			tune_value = <0xffffffff 0xffffffff>;
		};

		hs_tune12 {
			tune_name = "reg_direct";
			tune_value = <0xffffffff 0xffffffff>;
		};
	};

	ext_24_5m: clock-1 {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-output-names = "oscclk";
	};

	ext_200m: clock-2 {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-output-names = "ext-200m";
	};

	ext_26m: clock-3 {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-output-names = "ext-26m";
	};

	ext_1m: clock-4 {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-output-names = "ext-1m";
	};

	firmware {
		acpm_ipc: power-management {
			compatible = "google,gs101-acpm-ipc";
			#clock-cells = <1>;
			mboxes = <&ap2apm_mailbox>;
			shmem = <&apm_sram>;
		};

		trng {
			compatible = "arm,smccc-trng";
		};
	};

	pmu-0 {
		compatible = "arm,cortex-a520-pmu";
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster0>;
	};

	pmu-1 {
		compatible = "arm,cortex-a720-pmu";
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster1>;
	};

	pmu-2 {
		compatible = "arm,cortex-x4-pmu";
		interrupts = <GIC_PPI 7 IRQ_TYPE_LEVEL_HIGH &ppi_cluster2>;
	};

	pmu-3 {
		compatible = "arm,dsu-pmu";
		cpus = <&cpu0>, <&cpu1>, <&cpu2>, <&cpu3>,
		       <&cpu4>, <&cpu5>, <&cpu6>, <&cpu7>;
		interrupts = <GIC_SPI 178 IRQ_TYPE_LEVEL_HIGH 0>;
	};

	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	reserved_memory: reserved-memory {
		#address-cells = <2>;
		#size-cells = <1>;
		ranges;

		// ect_binary: ect_binary {
		// 	compatible = "exynos,ect_rmem";
		// 	reg = <0x0 0x90000000 0x00060000>;
		// };

		gsa_reserved_protected: gsa@90200000 {
			reg = <0x0 0x90200000 0x3ff000>;
			no-map;
		};

		// gsa_reserved_log: gsa@905ff000 {
		// 	reg = <0x0 0x905ff000 0x1000>;
		// 	no-map;
		// };
  //
		// gxp_scratchpad_reserved: gxp_scratchpad@91300000 {
		// 	reg = <0x0 0x91300000 0x00060000>;
		// 	no-map;
		// };
  //
		// iif_wait_table_reserved: iif_wait_table@91360000 {
		// 	reg = <0x0 0x91360000 0x0020000>;
		// 	no-map;
		// };
  //
		// iif_signal_table_reserved: iif_signal_table@91380000 {
		// 	reg = <0x0 0x91380000 0x0020000>;
		// 	no-map;
		// };
  //
		// gxp_secure_data_reserved: gxp_secure_data@91400000 {
		// 	reg = <0x0 0x91400000 0x00900000>;
		// 	no-map;
		// };
  //
		// gxp_fw_reserved: gxp_fw@91d00000 {
		// 	reg = <0x0 0x91d00000 0x00300000>;
		// 	no-map;
		// };
  //
		// gxp_mcu_fw_reserved: gxp_mcu_fw@92000000 {
		// 	reg = <0x0 0x92000000 0x00400000>;
		// 	no-map;
		// };

		tpu_fw_reserved_zumapro: tpu_fw@92e00000 {
			reg = <0x0 0x92e00000 0x01200000>;
			no-map;
		};

		aoc_reserve: aoc@94000000 {
			reg = <0x0 0x94000000 0x03000000>;
			no-map;
		};

		dss_log_reserved: dss_log_reserved@fd3f0000 {
			reg = <0 0xfd3f0000 0x0000e000>;
			no-map;
		};

		debug_kinfo_reserved: debug_kinfo_reserved@fd3fe000 {
			reg = <0 0xfd3fe000 0x00001000>;
			no-map;
		};

		bldr_log_reserved: bldr_log_reserved@fd800000 {
			reg = <0 0xfd800000 0x00100000>;
			no-map;
		};

		// cp_rmem: cp_rmem {
		// 	compatible = "exynos,modem_if";
		// 	reg = <0x0 0xeA400000 0x00c00000>;
		// 	rmem_index = <0>;
		// };
  //
		// cp_msi_rmem: cp_msi_rmem {
		// 	compatible = "exynos,modem_if";
		// 	reg = <0x0 0xf6200000 0x00001000>;
		// 	rmem_index = <1>;
		// };
  //
		// cp_rmem_1: cp_rmem_1 {
		// 	compatible = "exynos,modem_if";
		// 	reg = <0x0 0xe8000000 0x02000000>;
		// 	rmem_index = <2>;
		// };
  //
		// cp_aoc_rmem: cp_aoc_rmem {
		// 	compatible = "exynos,modem_if";
		// 	reg = <0x0 0x197fd000 0x00003000>;
		// 	rmem_index = <3>;
		// };

		xhci_dma_buffer: xhci_dma_buffer@17BB5000 {
			compatible = "xhci-dma-pool";
			reg = <0 0x17BB5000 0xB000>;
			no-map;
