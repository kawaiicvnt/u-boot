		drmdsim0: dsi@19440000 {
			compatible = "samsung,zuma-mipi-dsi";
			reg = <0x19440000 0x300>,
			      <0x19460100 0x700>,
			      <0x19460000 0x100>;
			reg-names = "dsi", "dphy", "dphy-extra";
			interrupts = <GIC_SPI 252 IRQ_TYPE_LEVEL_HIGH 0>;

			clocks = <&cmu_dpu CLK_GOUT_DPU_PCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM0_OSCCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM0_ALVCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM0_OSCCLK>;
			clock-names = "bus", "pll", "byte", "esc";

			vddcore-supply = <&reg_placeholder>;
			vddio-supply = <&reg_placeholder>;

			samsung,esc-clock-frequency = <20000000>;
			samsung,pll-clock-frequency = <26000000>;
			samsung,burst-clock-frequency = <756000000>;
			dsim,id = <0>;
			te_from = <0>;
			te-gpio = <&gpp0 3 0xf>;
			te-gpios = <&gpp0 3 GPIO_ACTIVE_HIGH>;
			phys = <&mipi_phy_dsim0_m4m4 0>;
			phy-names = "dsim";

			pinctrl-names = "hw_te_on", "hw_te_off";
			pinctrl-0 = <&disp_te_pri_on>;
			pinctrl-1 = <&disp_te_pri_off>;

			status = "disabled";

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;

					dsim0_to_decon0: endpoint {
						remote-endpoint = <&decon0_to_dsim>;
					};
				};
			};
		};

		drmdsim1: dsi@19450000 {
			compatible = "samsung,zuma-mipi-dsi";
			reg = <0x19450000 0x300>,
			      <0x19460900 0x700>,
			      <0x19460000 0x100>;
			reg-names = "dsi", "dphy", "dphy-extra";
			interrupts = <GIC_SPI 253 IRQ_TYPE_LEVEL_HIGH 0>;

			clocks = <&cmu_dpu CLK_GOUT_DPU_PCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM1_OSCCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM1_ALVCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DSIM1_OSCCLK>;
			clock-names = "bus", "pll", "byte", "esc";

			vddcore-supply = <&reg_placeholder>;
			vddio-supply = <&reg_placeholder>;

			samsung,esc-clock-frequency = <20000000>;
			samsung,pll-clock-frequency = <26000000>;
			samsung,burst-clock-frequency = <756000000>;
			dsim,id = <1>;
			te_from = <1>;
			te-gpio = <&gpp0 4 0xf>;
			te-gpios = <&gpp0 4 GPIO_ACTIVE_HIGH>;
			phys = <&mipi_phy_dsim0_m4m4 0>;
			phy-names = "dsim";

			pinctrl-names = "hw_te_on", "hw_te_off";
			pinctrl-0 = <&disp_te_sec_on>;
			pinctrl-1 = <&disp_te_sec_off>;

			status = "disabled";

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;

					dsim1_to_decon0: endpoint {
						remote-endpoint = <&decon0_to_dsim>;
					};
				};
			};
		};

		drmdecon0: decon0: display-controller@19470000 {
			compatible = "google,zuma-decon";
			reg = <0x19470000 0x6000>,
			      <0x19480000 0xe000>,
			      <0x19490000 0x10000>,
			      <0x194a0000 0xe000>;
			reg-names = "main", "win", "sub", "wincon";
			interrupts = <GIC_SPI 241 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 240 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 239 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "frame_start", "frame_done", "extra";

			clocks = <&cmu_dpu CLK_GOUT_DPU_PCLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DECON0_ACLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DECON0_ECLK>,
				 <&cmu_dpu CLK_GOUT_DPU_DECON0_VCLK>;
			clock-names = "pclk_decon0", "aclk_decon0",
				      "decon0_eclk", "decon0_vclk";

			iommus = <&sysmmu_dpuf0>, <&sysmmu_dpuf1>;

			status = "disabled";

			port {
				decon0_to_dsim: endpoint {
					remote-endpoint = <&dsim0_to_decon0>;
				};
			};
		};

		/* HSI1 GEN3A_0 */
		pcie_0_phy: pcie-phy@12140000 {
			compatible = "google,zuma-pcie-phy";
			reg = <0x12140000 0x3000>;
			samsung,pmu-syscon = <&pmu_system_controller>;
			samsung,fsys-sysreg = <&sysreg_hsi1>;
			#phy-cells = <0>;

			status = "disabled";
		};

		/* HSI1 GEN3A_0 */
		pcie_0:	pcie@12100000 {
			compatible = "google,zuma-pcie", "samsung,exynos5433-pcie";
			gpios = <&gph0 0 0x1 /* PERST */>;
			reg =  <0x12100000 0x2000	/* elbi base */
				0x12110000 0x5000   /* soc base */
				0x12130000 0xD000   /* udbg base */
				0x12140000 0x3000	/* phy base */
				0x12020000 0x2000	/* sysreg base */
				0x12400000 0x381000	/* DBI base */
				0x12120000 0x5000	/* phy pcs base */
				0x40FFE000 0x2000	/* configuration space */
				0x12170000 0x1000>;	/* I/A space */
			reg-names = "elbi", "soc", "udbg", "phy", "sysreg", "dbi", "pcs", "config", "ia";
			interrupts = <GIC_SPI 414 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 416 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 417 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 418 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 419 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 420 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "msi";
			samsung,pmu-syscon = <&pmu_system_controller>;
			pinctrl-names = "active";
			pinctrl-0 = <&pcie0_clkreq &pcie0_perst>;
			device_type = "pci";
			#address-cells = <3>;
			#size-cells = <2>;
			bus-range = <0x00 0xff>;
			/* non-prefetchable memory */
			ranges = <0x82000000 0 0x40000000 0x40000000 0 0x00FF0000>;
			ip-ver = <0x987500>;	/* zuma pro*/
			num-lanes = <2>;
			ch-num = <0>;
			pcie-clk-num = <0>;
			phy-clk-num = <0>;
			pcie-pm-qos-int = <200000>;
			separated-msi = <1>;
			use-cache-coherency = "false";
			use-pcieon-sleep = "false";
			use-msi = "false";
			support-msi64-addressing = "false";
			use-sicd = "false";
			use-sysmmu = "false";
			use-ia = "false";
			use-l1ss = "false";
			pmu-offset = <0x3ec4>;
			perst-delay-us = <20000>;
			max-link-speed = <3>;

			phys = <&pcie_0_phy>;
			status = "disabled";
		};

		pcie_1_phy: pcie-phy@13160000 {
			compatible = "google,zuma-pcie-phy";
			reg = <0x13160000 0x3000>;
			samsung,pmu-syscon = <&pmu_system_controller>;
			samsung,fsys-sysreg = <&sysreg_hsi2>;
			#phy-cells = <0>;

			status = "disabled";
		};

		/* HSI2 GEN3A_1 */
		pcie_1:	pcie@13120000 {
			compatible = "google,zuma-pcie", "samsung,exynos5433-pcie";
			gpios = <&gph3 0 0x1 /* PERST */>;
			reg = <0x13120000 0x2000	/* elbi base */
			       0x13130000 0x5000	/* soc base */
			       0x13150000 0xD000	/* udbg base */
			       0x13160000 0x3000	/* phy base */
			       0x13020000 0x2000	/* sysreg base */
			       0x13400000 0x381000	/* DBI base */
			       0x13140000 0x5000	/* phy pcs base */
			       0x60FFE000 0x2000	/* configuration space */
			       0x13100000 0x1000>;	/* I/A space */
			reg-names = "elbi", "soc", "udbg", "phy", "sysreg",
				    "dbi", "pcs", "config", "ia";
			interrupts = <GIC_SPI 439 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 441 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 442 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 443 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 444 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 445 IRQ_TYPE_LEVEL_HIGH 0>;
			interrupt-names = "msi";
			#interrupt-cells = <1>;
			interrupt-map-mask = <0 0 0 0>;
			interrupt-map = <0 0 0 0 &gic GIC_SPI 439 IRQ_TYPE_LEVEL_HIGH 0>;
			samsung,pmu-syscon = <&pmu_system_controller>;
			pinctrl-names = "active";
			pinctrl-0 = <&pcie1_clkreq &pcie1_perst
				     &pcie1_wlan_host_wake
				     &pcie1_wlan_reg_on
				     &pcie1_wlan_dev_wake>;
			device_type = "pci";
			#address-cells = <3>;
			#size-cells = <2>;
			bus-range = <0x00 0xff>;
			/* non-prefetchable memory */
			ranges = <0x82000000 0 0x60000000 0x60000000 0 0x00FF0000>;
			ip-ver = <0x987500>;
			num-lanes = <1>;
			ch-num = <1>;
			pcie-clk-num = <0>;
			phy-clk-num = <0>;
			pcie-pm-qos-int = <200000>;
			separated-msi = <1>;
			use-cache-coherency = "false";
			use-pcieon-sleep = "false";
			use-msi = "true";
			support-msi64-addressing = "false";
			use-sicd = "true";
			use-sysmmu = "false";
			use-ia = "false";
			use-l1ss = "true";
			pmu-offset = <0x3ec8>;
			ep-device-type = <0x1>;
			perst-delay-us = <15000>;
			pcie,wlan-gpio = <&gph3 4 0x1>;
			max-link-speed = <3>;
			customized-de-emphasis = "false";
			de-emphasis-value = <0>;

			phys = <&pcie_1_phy>;
			status = "disabled";
		};

		cmu_top: clock-controller@26040000 {
			compatible = "google,zuma-cmu-top";
			reg = <0x26040000 0x10000>;
			#clock-cells = <1>;

			clocks = <&ext_24_5m>;
			clock-names = "oscclk";
		};
		
		gpu: gpu@1f000000 {
			compatible = "google,zuma-mali", "arm,mali-valhall-csf";
			reg = <0x1f000000 0x480000>;
			clocks = <&ext_24_5m>;
			clock-names = "core";
			interrupt-names = "job", "mmu", "gpu";
			interrupts = <GIC_SPI 420 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 421 IRQ_TYPE_LEVEL_HIGH 0>,
				     <GIC_SPI 419 IRQ_TYPE_LEVEL_HIGH 0>;

		};
	};

	apm_sram: sram@15700000 {
		compatible = "mmio-sram";
		reg = <0x0 0x15700000 0x58000>;
		#address-cells = <1>;
		#size-cells = <1>;
		ranges = <0x0 0x0 0x15700000 0x58000>;
	};

	timer {
		compatible = "arm,armv8-timer";
		interrupts =
		   <GIC_PPI 13 (GIC_CPU_MASK_SIMPLE(8) | IRQ_TYPE_LEVEL_LOW) 0>,
		   <GIC_PPI 14 (GIC_CPU_MASK_SIMPLE(8) | IRQ_TYPE_LEVEL_LOW) 0>,
		   <GIC_PPI 11 (GIC_CPU_MASK_SIMPLE(8) | IRQ_TYPE_LEVEL_LOW) 0>,
		   <GIC_PPI 10 (GIC_CPU_MASK_SIMPLE(8) | IRQ_TYPE_LEVEL_LOW) 0>;
	};
};

#include "zumapro-pinctrl.dtsi"
